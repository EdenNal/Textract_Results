    "# python function to remove first n columns of a csv file and save to a new file in new directory\n",
    "import csv\n",
    "os.makedirs('Removed_Columns_Manual_CSVs', exist_ok=True)\n",
    "os.makedirs('Removed_Columns_AWS_CSVs', exist_ok=True)\n",
    "def remove_first_n_columns(input_file_path, output_file_path, n):  \n",
    "    with open(input_file_path, mode='r', newline='') as input_csvfile:\n",
    "        csvreader = csv.reader(input_csvfile)\n",
    "        rows = [row[n:] for row in csvreader]  # Skip the first n columns\n",
    "    with open(output_file_path, mode='w', newline='') as output_csvfile:\n",
    "        csvwriter = csv.writer(output_csvfile)\n",
    "        csvwriter.writerows(rows)\n",
    "for i in range(1,53):\n",
    "    remove_first_n_columns(f'Cleaned_With_Columns/Cleaned_Manual_CSVs/cdi_ca_1956_wk_prov_dbs_Part{i}.csv', f'Removed_Columns_Manual_CSVs/padded_cdi_ca_1956_wk_prov_dbs_Part{i}.csv', 2)\n",
    "    remove_first_n_columns(f'CleanedCSVs/cdi_ca_1956_wk_prov_dbs_Part{i}_tables.csv', f'Removed_Columns_AWS_CSVs/padded_cdi_ca_1956_wk_prov_dbs_Part{i}_tables.csv', 2)\n",
    "    remove_first_n_columns(f'CleanedCSVs/cdi_ca_1956_wk_prov_dbs_Part{i}_confidences.csv', f'Removed_Columns_AWS_CSVs/padded_cdi_ca_1956_wk_prov_dbs_Part{i}_confidences.csv', 2)\n"
   ]
