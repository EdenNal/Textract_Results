    "# python function to remove first n rows from a csv file and save to a new file\n",
    "import os\n",
    "import csv  \n",
    "\n",
    "os.makedirs('CleanedCSVs', exist_ok=True)\n",
    "def remove_first_n_rows(input_file_path, output_file_path, n):  \n",
    "    with open(input_file_path, mode='r', newline='') as input_csvfile:\n",
    "        csvreader = csv.reader(input_csvfile)\n",
    "        rows = list(csvreader)[n:]  # Skip the first n rows\n",
    "    with open(output_file_path, mode='w', newline='') as output_csvfile:\n",
    "        csvwriter = csv.writer(output_csvfile)\n",
    "        csvwriter.writerows(rows) \n",
    "\n",
    "# Cleaned wekk 32 separately\n",
