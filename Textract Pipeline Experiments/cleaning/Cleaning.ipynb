    "# output_table_file = f'CleanedCSVs/cdi_ca_1956_wk_prov_dbs_Part32_tables.csv'\n",
    "# output_confidences_file = f'CleanedCSVs/cdi_ca_1956_wk_prov_dbs_Part32_confidences.csv'\n",
    "# n_rows_to_remove = count_csv_rows_until_value(input_table_file, 'K')\n",
    "# remove_first_n_rows(input_table_file, output_table_file, n_rows_to_remove)\n",
    "# remove_first_n_rows(input_confidences_file, output_confidences_file, n_rows_to_remove)\n",
    "# print(count_csv_rows(output_table_file)==count_csv_rows(output_confidences_file))\n",
    "\n",
    "for i in range(1,53):\n",
    "    input_table_file = f'TablesAndConfidence/cdi_ca_1956_wk_prov_dbs_Part{i}_tables.csv'\n",
    "    input_confidences_file = f'TablesAndConfidence/cdi_ca_1956_wk_prov_dbs_Part{i}_confidences.csv'\n",
    "    output_table_file = f'CleanedCSVs/cdi_ca_1956_wk_prov_dbs_Part{i}_tables.csv'\n",
    "    output_confidences_file = f'CleanedCSVs/cdi_ca_1956_wk_prov_dbs_Part{i}_confidences.csv'\n",
    "    n_rows_to_remove = count_csv_rows_until_value(input_table_file, '1')\n",
